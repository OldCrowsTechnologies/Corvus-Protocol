{
  "name": "corvus-protocol",
  "version": "0.1.0",
  "description": "Corvus Protocol: The Omen Wars — mythological idle tower-defense (Old Crows Wireless / Mad Apps)",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build:android": "eas build --platform android --profile preview",
    "build:android:prod": "eas build --platform android --profile production",
    "typecheck": "tsc --noEmit",
    "stress": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types --import ./stress/register.mjs stress/index.mjs",
    "security": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types --import ./stress/register.mjs stress/security.mjs",
    "harden": "npm run typecheck && npm run stress && npm run security"
  },
  "dependencies": {
    "@expo-google-fonts/cinzel": "^0.4.1",
    "@expo-google-fonts/space-grotesk": "^0.4.1",
    "@expo-google-fonts/space-mono": "^0.4.1",
    "@expo/metro-runtime": "~5.0.5",
    "@expo/vector-icons": "^14.1.0",
    "@react-native-async-storage/async-storage": "2.1.2",
    "@react-navigation/native": "^7.0.14",
    "@react-navigation/native-stack": "^7.2.0",
    "expo": "~53.0.0",
    "expo-asset": "~11.1.7",
    "expo-audio": "~0.4.9",
    "expo-font": "~13.3.2",
    "expo-haptics": "~14.1.4",
    "expo-linear-gradient": "~14.1.5",
    "expo-status-bar": "~2.2.3",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-native": "0.79.6",
    "react-native-safe-area-context": "5.4.0",
    "react-native-screens": "~4.11.1",
    "react-native-svg": "15.11.2",
    "react-native-web": "^0.20.0",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@types/react": "~19.0.10",
    "babel-plugin-module-resolver": "^5.0.2",
    "puppeteer-core": "^23.11.1",
    "typescript": "~5.8.3"
  },
  "private": true
}
